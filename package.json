{
  "name": "sidikoff-digital",
  "version": "2.0.0",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "build:turbo": "next build --turbopack",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "build:check": "pnpm type-check && pnpm lint && pnpm build",
    "preview": "pnpm build && pnpm start",
    "clean": "rimraf .next out dist",
    "clear-cache": "pnpm run clean",
    "analyze": "ANALYZE=true pnpm build",
    "test": "echo \"No tests specified\" && exit 0"
  },
  "dependencies": {
    "@vercel/analytics": "^1.5.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.552.0",
    "next": "^16.1.0",
    "nodemailer": "^7.0.10",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@next/bundle-analyzer": "^16.0.1",
    "@tailwindcss/postcss": "^4.1.16",
    "@types/node": "^24.10.0",
    "@types/nodemailer": "^7.0.3",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "critters": "^0.0.22",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.0.10",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.1.16",
    "typescript": "^5.9.3"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11",
    "not op_mini all"
  ]
}